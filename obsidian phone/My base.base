formulas:
  Untitled: ""
  Filefilder: folder
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.tags
      - file.folder
    summaries:
      formula.Filefilder: Empty
  - type: list
    name: View
    order:
      - file.name
      - file.folder
      - file.tags
    sort:
      - property: file.ctime
        direction: DESC
    image: note.tags
    cardSize: 110
    imageAspectRatio: 0.7
    markers: number
    indentProperties: true
